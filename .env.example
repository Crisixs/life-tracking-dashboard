# ─── Life Tracking Dashboard – Umgebungsvariablen ───
# Kopiere diese Datei zu .env und fülle die Werte aus.
# .env wird NICHT in Git committed (steht in .gitignore).

# ─── Backend / Authentifizierung ───
SERVER_PORT=3001
JWT_SECRET=aendere-mich-in-produktion-langer-zufaelliger-string
# DB_PATH=/mnt/hdd/dashboard/dashboard.db   ← HDD-Pfad auf dem Pi
DB_PATH=data/dashboard.db

# ─── Home Assistant ───
# HASS_URL=http://localhost:8123
# HASS_TOKEN=

# ─── Nextcloud ───
# NEXTCLOUD_URL=http://localhost:8080
# NEXTCLOUD_USER=
# NEXTCLOUD_PASSWORD=

# ─── Pi-hole ───
# PIHOLE_URL=http://localhost:80/admin
# PIHOLE_API_KEY=

# ─── App Settings ───
VITE_APP_TITLE=Life Tracking Dashboard
VITE_APP_PORT=3000
